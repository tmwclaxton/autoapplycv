APP_NAME=AutoCVApply
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production behind HTTPS (e.g. Cloudflare): APP_URL=https://autocvapply.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Sail: use redis (redis service in compose.yaml). SQLite-only local: database
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
# Sail: redis (Docker service). Host-only PHP: 127.0.0.1
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=postal
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@autocvapply.com"
MAIL_FROM_NAME="${APP_NAME}"

POSTAL_API_KEY=
POSTAL_BASE_URL=https://postal.grantgunner.org
POSTAL_WEBHOOK_SECRET=

WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URL="${APP_URL}/authenticate"

NANOGPT_API_KEY=
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1
NANOGPT_TIMEOUT_SECONDS=120
NANOGPT_CONNECT_TIMEOUT_SECONDS=15
NANOGPT_VISION_MODEL=openai/gpt-4.1-mini:speed
NANOGPT_IMAGE_BASE_URL=https://nano-gpt.com/v1
NANOGPT_IMAGE_MODEL=recraft-ai/recraft-v4.1/text-to-image
NANOGPT_IMAGE_SIZE=1024x576
# CV extraction (optional overrides; defaults live in config/cv.php)
# CV_MIN_EXTRACTED_TEXT_LENGTH=80
# CV_MAX_RAW_TEXT_CHARS=32000
# CV_OCR_ENABLED=true
# CV_OCR_LANGUAGE=eng
# CV_OCR_PSM=3
# CV_OCR_DPI=200
# CV_OCR_MAX_PDF_PAGES=10
# CV_OCR_TIMEOUT_SECONDS=120
# CV_OCR_USE_VISION_FALLBACK=true
# CV_OCR_PREFER_PDF_TESSERACT=false
# BLOG_HERO_IMAGE_DISK=public
# NANOGPT_CV_MODEL=google/gemini-3.1-flash-lite:throughput
# NANOGPT_VISION_MODEL=openai/gpt-4.1-mini:speed

GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_WEBHOOK_SECRET=
# GOCARDLESS_ENVIRONMENT=live

# Discord community bot — npm run discord:setup after inviting the bot to your server
DISCORD_APPLICATION_ID=1523097041209921706
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# LinkedIn Auto Apply E2E (local only, never commit real values)
LINKEDIN_TEST_EMAIL=
LINKEDIN_TEST_PASSWORD=
# Set LINKEDIN_LIVE_E2E=1 to run live full-flow PHPUnit / npm tests
# LINKEDIN_LIVE_E2E=1
# Optional: AutoCVApply API connection for Draft All during live LinkedIn E2E
# EXTENSION_E2E_API_BASE=http://localhost:8000
# EXTENSION_E2E_TOKEN=
