{
    "manifest_version": 3,
    "name": "AutoCVApply",
    "version": "2.5.0",
    "description": "Auto-fill job forms, draft answers with AI, run apply bots, and update your profile without leaving the page.",
    "permissions": ["storage", "tabs", "scripting", "sidePanel", "contextMenus", "webNavigation"],
    "host_permissions": [
        "https://*.workday.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.indeed.com/*",
        "https://apply.indeed.com/*",
        "https://*.linkedin.com/*",
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.lever.co/*",
        "https://*.glassdoor.com/*",
        "https://*.glassdoor.co.uk/*",
        "https://*.monster.com/*",
        "https://*.welcometothejungle.com/*",
        "https://autocvapply.com/*"
    ],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "AutoCVApply",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.workday.com/*",
                "https://*.myworkdayjobs.com/*",
                "https://*.indeed.com/*",
                "https://apply.indeed.com/*",
                "https://*.linkedin.com/*",
                "https://*.greenhouse.io/*",
                "https://jobs.lever.co/*",
                "https://*.lever.co/*",
                "https://*.glassdoor.com/*",
                "https://*.glassdoor.co.uk/*",
                "https://*.monster.com/*",
                "https://*.welcometothejungle.com/*"
            ],
            "js": [
                "form-heuristics.js",
                "focus-tracker.js",
                "portal-bar.js",
                "content.js"
            ],
            "all_frames": true,
            "run_at": "document_idle"
        }
    ]
}
